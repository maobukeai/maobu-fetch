{
  "manifest_version": 3,
  "name": "猫步下载器 · Maobu Fetch",
  "short_name": "Maobu Fetch",
  "version": "0.5.7",
  "description": "安全地接管下载并将页面媒体发送到猫步下载器。",
  "permissions": [
    "contextMenus",
    "cookies",
    "downloads",
    "scripting",
    "storage",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "http://127.0.0.1:17433/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "icons": {
    "128": "src/icon128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "猫步下载器",
    "default_icon": "src/icon128.png"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
