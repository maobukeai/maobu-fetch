{
  "manifest_version": 3,
  "name": "LumaGet Browser Companion",
  "short_name": "LumaGet",
  "version": "0.4.0",
  "description": "安全地接管下载并将页面媒体发送到 LumaGet。",
  "permissions": ["contextMenus", "downloads", "storage", "tabs", "notifications"],
  "host_permissions": ["http://127.0.0.1:17433/*", "http://*/*", "https://*/*"],
  "background": { "service_worker": "background.js", "type": "module" },
  "icons": { "128": "icon128.png" },
  "action": { "default_popup": "popup.html", "default_title": "LumaGet", "default_icon": "icon128.png" },
  "content_scripts": [{ "matches": ["http://*/*", "https://*/*"], "js": ["content.js"], "run_at": "document_idle" }]
}
