{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LumaGet",
  "version": "0.2.0",
  "identifier": "app.lumaget.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\fetch-media-tools.ps1; pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "title": "LumaGet",
      "width": 1280,
      "height": 800,
      "minWidth": 1060,
      "minHeight": 680,
      "center": true,
      "decorations": true,
      "transparent": false
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/icon.ico"],
    "resources": { "resources/tools/*": "tools/" },
    "shortDescription": "Windows 原生效率型下载器",
    "longDescription": "支持可靠续传、队列调度、浏览器接管与媒体下载的开源 Windows 下载管理器。",
    "windows": { "webviewInstallMode": { "type": "downloadBootstrapper", "silent": true } }
  }
}
