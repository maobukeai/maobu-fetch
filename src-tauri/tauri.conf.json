{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maobu Fetch",
  "version": "0.5.0",
  "identifier": "app.lumaget.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "title": "猫步下载器 · Maobu Fetch",
      "width": 1024,
      "height": 720,
      "minWidth": 780,
      "minHeight": 540,
      "center": true,
      "decorations": false,
      "transparent": false,
      "resizable": true
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/icon.ico"],
    "shortDescription": "Windows 原生效率型下载器",
    "longDescription": "支持可靠续传、队列调度、浏览器接管与媒体下载的开源 Windows 下载管理器。",
    "windows": { "webviewInstallMode": { "type": "downloadBootstrapper", "silent": true } }
  }
}
