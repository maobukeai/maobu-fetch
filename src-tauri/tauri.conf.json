{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LumaGet",
  "version": "0.1.0",
  "identifier": "app.lumaget.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "title": "LumaGet",
      "width": 1280,
      "height": 800,
      "minWidth": 1060,
      "minHeight": 680,
      "center": true,
      "decorations": true,
      "transparent": false
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "shortDescription": "Download beautifully.",
    "longDescription": "A modern open-source download manager with browser integration.",
    "windows": { "webviewInstallMode": { "type": "downloadBootstrapper", "silent": true } }
  }
}
